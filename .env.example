# ZEBRA · LEAD STRESS — example environment configuration
# Copy to .env for local dev, or define these in Easypanel for production.
# In production, env vars WIN over .secrets/keys.json (see SPEC §6).

# --- API keys (backend only — never exposed to the frontend) ---
# If set, these take priority over .secrets/keys.json and cannot be
# overwritten from the Settings UI.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Persistent data directory (see SPEC §7, §14) ---
# Local dev default: ./data   |   Production (Easypanel volume): /data
DATA_DIR=./data

NODE_ENV=development
