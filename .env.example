# Supabase — server-side only (service_role bypasses RLS, never expose to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM key for encrypting provider API keys at rest.
# Generate with: openssl rand -hex 32
# WARNING: rotating this invalidates all previously stored provider keys.
KEY_ENCRYPTION_SECRET=

# Optional build tag shown in the footer.
NEXT_PUBLIC_BUILD_TAG=

# ---------------------------------------------------------------------------
# Login "Entrar con Google" (restricts access to the company domain).
# The app talks to Google directly and mints its own signed session cookie;
# no external auth service is involved.
# ---------------------------------------------------------------------------

# OAuth Client (Google Cloud Console, "Aplicacion web").
# Authorized redirect URI must be: <app base url>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=

# Company domain allowed to log in. Only emails ending in @<this> get access.
AUTH_ALLOWED_DOMAIN=zebradigital.marketing

# Public base URL of the app. Recommended behind the EasyPanel proxy so the
# OAuth redirect URI is deterministic. No trailing slash.
# Example: https://dashboard-prompt-benchmark.9qd6cz.easypanel.host
AUTH_BASE_URL=
